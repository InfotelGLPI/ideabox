{% if ideas|length > 0 %}
<div class="row g-3 ideabox-list">
    {% for idea in ideas %}
    <div class="col-12 col-md-6" id="anchor{{ idea.id }}">
        <div class="card h-100 ideabox-card">

            <div class="card-header d-flex align-items-center gap-2 py-2">
                <span class="avatar avatar-sm rounded flex-shrink-0"
                      style="{{ idea.avatar_style|raw }}"
                      title="{{ idea.user_name }}">
                    {% if not idea.has_thumbnail %}{{ idea.user_initials }}{% endif %}
                </span>
                <div class="flex-grow-1 min-w-0">
                    <div class="fw-semibold text-truncate" style="font-size:.875rem">{{ idea.user_name }}</div>
                    <div class="text-muted" style="font-size:.75rem">{{ idea.date_relative }}</div>
                </div>
                <span class="badge ms-1 badge-outline-secondary flex-shrink-0"
                      style="background-color:{{ idea.state_color }};color:#FFF">
                    {{ idea.state_name }}
                </span>
            </div>

            <div class="card-body py-2">
                <div class="ideabox-title mb-2">{{ idea.link|raw }}</div>
                {% if idea.description_long %}
                    <a class="text-muted ideabox-expand-link"
                       href="#anchor{{ idea.id }}"
                       onclick="this.style.display='none';document.getElementById('desc{{ idea.id }}').style.display='block';return false;">
                        <i class="ti ti-eye me-1"></i>{{ idea.label_read_desc }}
                    </a>
                    <div id="desc{{ idea.id }}" class="ideabox-description mt-1" style="display:none">
                        {{ idea.description|raw }}
                    </div>
                {% elseif idea.description %}
                    <div class="ideabox-description">{{ idea.description|raw }}</div>
                {% endif %}
            </div>

            {% if idea.last_comment %}
            <div class="px-3 py-1 border-top ideabox-last-comment">
                <i class="ti ti-message me-1"></i>
                {{ idea.label_commented_by }}
                <strong>{{ idea.last_comment.user_name }}</strong>
                &mdash; {{ idea.last_comment.date_relative }}
            </div>
            {% endif %}

            <div class="card-footer d-flex align-items-center gap-2 py-2">
                {{ idea.vote_form|raw }}
                {% if idea.comments_count > 0 %}
                    <button class="btn btn-sm btn-ghost-secondary d-flex align-items-center gap-1"
                            data-bs-toggle="modal"
                            data-bs-target="#seecomments{{ idea.id }}">
                        <i class="ti ti-message"></i>
                        <span class="badge badge-outline-secondary rounded-pill">{{ idea.comments_count }}</span>
                    </button>
                    {{ idea.comments_modal|raw }}
                {% else %}
                    {{ idea.add_comment_form|raw }}
                {% endif %}
{#                <div class="ms-auto">{{ idea.subscribe_form|raw }}</div>#}
            </div>

        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
