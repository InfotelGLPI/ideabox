<div class="ideabox-comments p-3">
    <div class="d-flex align-items-center gap-2 mb-3 pb-2 border-bottom">
        <i class="ti ti-messages text-primary fs-4"></i>
        <span class="fw-semibold">{{ count }} {{ label_comments }}</span>
    </div>

    <div class="ideabox-comment-list">
        {% for comment in comments %}
        <div class="d-flex gap-3 py-3 {% if not loop.last %}border-bottom{% endif %}">
            <span class="avatar avatar-sm rounded flex-shrink-0"
                  style="{{ comment.avatar_style|raw }}"
                  title="{{ comment.user_name }}">
                {% if not comment.has_thumbnail %}{{ comment.user_initials }}{% endif %}
            </span>
            <div class="flex-grow-1 min-w-0">
                <div class="d-flex align-items-baseline gap-2 mb-1 flex-wrap">
                    <span class="fw-semibold" style="font-size:.875rem">{{ comment.user_name_link|raw }}</span>
                    <span class="text-muted" style="font-size:.8rem">{{ comment.date_relative }}</span>
                    {% if comment.can_delete %}
                    <div class="ms-auto">{{ comment.delete_form|raw }}</div>
                    {% endif %}
                </div>
                <div class="ideabox-comment-text">{{ comment.text|raw }}</div>
            </div>
        </div>
        {% endfor %}
    </div>

    {% if not from_idea and add_comment_form %}
    <div class="mt-3 pt-2 border-top">{{ add_comment_form|raw }}</div>
    {% endif %}
</div>
